# Required
GEMINI_API_KEY=

# Upstream Gemini settings
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_HTTP_PROXY=
DEFAULT_MODEL=gemini-3-pro-image-preview

# Data and job runtime
DATA_DIR=./data
MAX_IMAGES_PER_JOB=1
MAX_REFERENCE_IMAGES=14
JOB_WORKERS=2
JOB_QUEUE_MAX=100
JOB_TIMEOUT_SEC_DEFAULT=120
JOB_TIMEOUT_SEC_MIN=15
JOB_TIMEOUT_SEC_MAX=600
JOB_WATCHDOG_GRACE_SEC=20
JOB_AUTH_MODE=TOKEN
JOB_TTL_DAYS=30
IDEMPOTENCY_TTL_SEC=86400

# Billing and limits
RATE_LIMIT_PER_MINUTE=60
ADMIN_API_KEY=
BILLING_MODE=INTERNAL
BUDGET_USD=100
PRICING_TABLE_PATH=
GOOGLE_REPORTED_SPEND_USD=
GOOGLE_REPORTED_REMAINING_USD=

# Logging
LOG_DIR=./data/logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=3

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
